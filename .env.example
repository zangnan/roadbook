# 高德地图 Web 端 Key（用于地图展示 AMap.Map）
AMAP_WEB_AK=xxx

# 高德地图 Web 服务 Key（用于逆地理编码 API）
AMAP_SERVER_AK=xxx

# 原图压缩质量 (1-100)，数值越小文件越小但质量越低
ORIGINAL_IMAGE_QUALITY=80

# 坐标合并阈值 - 距离阈值（米）
DISTANCE_THRESHOLD=1000

# 坐标合并阈值 - 时间阈值（秒）
TIME_THRESHOLD=7200

# 缓存类型: 'sqlite' 或 'json'
CACHE_TYPE=sqlite

# 照片根目录（相对于 exe 所在目录）
# 相对路径示例：\photo
PHOTO_BASE_DIR=\photo

# 输出根目录（相对于 exe 所在目录）
# 相对路径示例：\output
OUTPUT_BASE_DIR=\output

# 端口配置
WEB_PORT=18443
DESKTOP_PORT=12255