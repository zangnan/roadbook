  "scenic_guides": {
    "圆明新园": {
      "description": "圆明新园是以北京圆明园为蓝本，按1:1比例精选复原而成的古典园林景区，再现了清代皇家园林的宏伟与精致。园内有正大光明、九州清晏、蓬岛瑶台等景点，还融合了现代游乐设施和表演。",
      "location": "广东省珠海市香洲区九洲大道石林山",
      "name": "圆明新园",
      "opening_hours": "08:00-18:00",
      "recommended_visit_time": "3-4小时",
      "ticket_info": "免费（部分演出另收费）",
      "tips": [
        "适合穿汉服拍照，很出片",
        "附近停车较紧张，建议早点到"
      ]
    },
    "孙中山故居纪念馆": {
      "description": "孙中山故居是孙中山先生出生和成长的地方，包括故居、纪念馆和翠亨民居展示区。故居为中西合璧的二层小楼，纪念馆内陈列了大量孙中山生平文物和图片，是了解近代历史的重要场所。",
      "location": "广东省中山市翠亨村",
      "name": "孙中山故居纪念馆",
      "opening_hours": "09:00-17:00（周一闭馆）",
      "recommended_visit_time": "2小时",
      "ticket_info": "免费（需预约）",
      "tips": [
        "周一闭馆，请注意安排日期",
        "可顺道游览翠亨村其他历史建筑"
      ]
    },
    "广州塔": {
      "description": "广州塔又称广州新电视塔，昵称小蛮腰，总高600米，是中国第一高塔。塔身造型纤细优美，内部设有观景平台、摩天轮、旋转餐厅等设施。登顶可俯瞰珠江全景和广州城市天际线，夜间灯光秀尤为壮观。",
      "location": "广东省广州市海珠区阅江西路222号",
      "name": "广州塔",
      "opening_hours": "09:30-22:30",
      "recommended_visit_time": "2-3小时",
      "ticket_info": "成人票150元（433米观光层），摩天轮套票298元",
      "tips": [
