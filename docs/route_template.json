{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "RoadBook - 自驾路书模板",
  "description": "标准化自驾路书JSON模板，适用于AI识别和自动填充",
  "type": "object",
  "required": ["basic_info", "daily_itinerary", "budget"],

  "definitions": {
    "daily_itinerary": {
      "type": "object",
      "required": ["day_number", "date", "origin", "destination", "distance_km", "duration_hours", "elevation_m"],
      "properties": {
        "day_number": {
          "type": "integer",
          "description": "第几天（如1、2、3...）",
          "minimum": 1
        },
        "date": {
          "type": "string",
          "description": "日期（格式：yyyy-MM-dd）"
        },
        "origin": {
          "type": "string",
          "description": "出发地点"
        },
        "destination": {
          "type": "string",
          "description": "目的地点"
        },
        "distance_km": {
          "type": "number",
          "description": "当日里程（公里）"
        },
        "duration_hours": {
          "type": "number",
          "description": "当日车程（小时）"
        },
        "elevation_m": {
          "type": "string",
          "description": "海拔范围（格式：min-max，如20-190）"
        },
        "route": {
          "type": "string",
          "description": "途经路线/高速公路"
        },
        "highlights": {
          "type": "array",
          "description": "景点列表",
          "items": { "type": "string" }
        },
        "accommodation": {
          "type": "string",
          "description": "住宿地点（住宿明细见 budget.accommodation）"
        },
        "food": {
          "type": "array",
          "description": "推荐美食",
          "items": { "type": "string" }
        },
        "tips": {
          "type": "array",
          "description": "避坑提示",
          "items": { "type": "string" }
        },
        "gas_station": {
          "type": "string",
          "description": "推荐加油地点"
        },
        "notes": {
          "type": "string",
          "description": "其他备注"
        }
      }
    },

    "budget_item": {
      "type": "object",
      "properties": {
        "item": { "type": "string" },
        "formula": { "type": "string" },
        "total": { "type": "number" },
        "per_person": { "type": "number" },
        "per_group": { "type": "number" }
      }
    }
  },

  "properties": {
    "basic_info": {
      "type": "object",
      "required": ["travel_date_start", "travel_date_end", "car_type", "people_count", "total_distance_km"],
      "properties": {
        "title": {
          "type": "string",
          "description": "路书标题"
        },
        "travel_date_start": {
          "type": "string",
          "description": "出行开始日期（格式：yyyy-MM-dd）"
        },
        "travel_date_end": {
          "type": "string",
          "description": "出行结束日期（格式：yyyy-MM-dd）"
        },
        "days": {
          "type": "integer",
          "description": "总天数"
        },
        "car_type": {
          "type": "string",
          "description": "车型"
        },
        "people_count": {
          "type": "integer",
          "description": "出行人数"
        },
        "room_count": {
          "type": "integer",
          "description": "房间数量"
        },
        "total_distance_km": {
          "type": "number",
          "description": "全程里程（公里）"
        },
        "fuel_consumption": {
          "type": "string",
          "description": "油耗（如6.5L/100km）"
        },
        "fuel_price": {
          "type": "number",
          "description": "油价（元/升）"
        },
        "elevation_range": {
          "type": "string",
          "description": "全程海拔范围（如20-1400m）"
        },
        "high_altitude_warning": {
          "type": "boolean",
          "description": "是否有高反风险"
        },
        "route_summary": {
          "type": "string",
          "description": "路线概要"
        }
      }
    },

    "daily_itinerary": {
      "type": "array",
      "description": "每日行程列表",
      "items": { "$ref": "#/definitions/daily_itinerary" }
    },

    "budget": {
      "type": "object",
      "description": "费用明细总表",
      "properties": {
        "transportation": {
          "type": "object",
          "description": "交通费用：油费 + 过路费",
          "properties": {
            "fuel_total_liters": { "type": "number", "description": "总油耗（升），计算公式：总里程 × 油耗 ÷ 100" },
            "fuel_cost": { "type": "number", "description": "油费（元）" },
            "toll_fees": { "type": "number", "description": "过路费（元）" },
            "transportation_total": { "type": "number", "description": "交通合计 = 油费 + 过路费" },
            "per_person": { "type": "number", "description": "人均交通费" }
          }
        },
        "accommodation": {
          "type": "array",
          "description": "住宿费用明细",
          "items": {
            "type": "object",
            "properties": {
              "location": { "type": "string", "description": "住宿地点" },
              "type": { "type": "string", "description": "酒店类型" },
              "price_per_room": { "type": "number", "description": "每间房价（元）" },
              "nights": { "type": "integer", "description": "住宿晚数" },
              "rooms": { "type": "integer", "description": "房间数量" }
            }
          }
        },
        "food": {
          "type": "object",
          "description": "餐饮费用",
          "properties": {
            "daily_budget_per_person": { "type": "number", "description": "人均日餐饮预算（元）" },
            "days": { "type": "integer", "description": "天数" },
            "per_person": { "type": "number", "description": "人均餐饮总计 = 日预算 × 天数" },
            "group_total": { "type": "number", "description": "团队餐饮总计 = 人均 × 人数" }
          }
        },
        "tickets": {
          "type": "array",
          "description": "景点门票明细",
          "items": {
            "type": "object",
            "properties": {
              "item": { "type": "string", "description": "景点名称" },
              "total": { "type": "number", "description": "合计金额（元）" },
              "remark": { "type": "string", "description": "备注（如：2大1小）" }
            }
          }
        },
        "misc": {
          "type": "array",
          "description": "杂费明细",
          "items": {
            "type": "object",
            "properties": {
              "item": { "type": "string", "description": "杂费项目" },
              "total": { "type": "number", "description": "合计金额（元）" }
            }
          }
        },
        "grand_total": {
          "type": "object",
          "description": "总费用",
          "properties": {
            "per_person": { "type": "number", "description": "人均总费用 = 人均交通 + 人均住宿 + 人均餐饮 + 人均门票 + 人均杂费" },
            "group_total": { "type": "number", "description": "团队总费用" }
          }
        }
      }
    },

    "checklist": {
      "type": "array",
      "description": "出行必备提醒",
      "items": {
        "type": "object",
        "properties": {
          "category": { "type": "string" },
          "items": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
